{
  "name": "mockbook-qa-sandbox",
  "version": "1.0.0",
  "description": "Sportsbook QA sandbox demonstrating API, SQL, regression, and AI-assisted testing",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:critical": "playwright test --grep @critical",
    "test:api": "playwright test tests/api",
    "test:e2e": "playwright test tests/e2e",
    "test:sql": "playwright test tests/sql",
    "report": "playwright show-report",
    "report:email": "node scripts/email-report.js",
    "ai:analyze-trace": "node scripts/analyze-trace.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "nodemailer": "^6.9.15",
    "typescript": "^5.6.0"
  }
}
